<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>2028 Hat-in-Ring Radar</title>
<style>
:root{
  color-scheme: light;
  --bg:#f6f5f1; --panel:#ffffff; --ink:#1a1a1a; --muted:#6b6b6b; --line:#e3e1da;
  --dem:#2f6fd1; --rep:#d23b3b; --lib:#c79a18; --ind:#3b9c8a; --other:#7a7a7a;
  --t5:#c0392b; --t4:#e07a1f; --t3:#d4a017; --t2:#2f6fd1; --t1:#7d8794; --t0:#aab0b6;
  --good:#1f9d55; --bad:#c0392b;
  --shadow:0 1px 2px rgba(20,20,20,.05),0 1px 1px rgba(20,20,20,.04);
}
*{box-sizing:border-box}
body{margin:0;background:var(--bg);color:var(--ink);
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
  font-size:14px;line-height:1.45;-webkit-font-smoothing:antialiased}
h1,h2,h3{font-family:Georgia,"Times New Roman",serif;font-weight:600;letter-spacing:-.01em;margin:0}
a{color:var(--dem);text-decoration:none}
.wrap{max-width:1180px;margin:0 auto;padding:22px 20px 60px}
header.top{display:flex;flex-wrap:wrap;align-items:flex-end;gap:12px;justify-content:space-between;
  border-bottom:2px solid var(--ink);padding-bottom:14px;margin-bottom:18px}
.brand h1{font-size:30px;line-height:1.05}
.brand .sub{color:var(--muted);font-size:12.5px;margin-top:4px;letter-spacing:.02em;text-transform:uppercase}
.asof{font-size:12px;color:var(--muted);text-align:right}
.asof b{color:var(--ink)}
.asof .buildstamp{display:inline-block;margin-top:3px;font-size:11px;opacity:.85}
.asof .buildstamp::before{content:"⟳ ";font-weight:600}
.stats{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:18px}
.stat{background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:11px 12px;box-shadow:var(--shadow)}
.stat .n{font-family:Georgia,serif;font-size:24px;font-weight:600;line-height:1}
.stat .l{font-size:10.5px;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;margin-top:5px}
.stat .dot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:5px;vertical-align:1px}
.toolbar{position:sticky;top:0;z-index:20;background:var(--bg);padding:10px 0;margin-bottom:6px;
  border-bottom:1px solid var(--line);display:flex;flex-wrap:wrap;gap:8px;align-items:center}
.toolbar .grow{flex:1 1 180px}
input[type=search],select{font:inherit;padding:7px 9px;border:1px solid var(--line);border-radius:8px;background:#fff;color:var(--ink)}
input[type=search]{width:100%}
.chips{display:flex;flex-wrap:wrap;gap:6px}
.chip{border:1px solid var(--line);background:#fff;border-radius:999px;padding:5px 11px;font-size:12.5px;cursor:pointer;color:var(--muted);user-select:none}
.chip.on{background:var(--ink);color:#fff;border-color:var(--ink)}
.chip.party.on[data-v=Democrat]{background:var(--dem);border-color:var(--dem)}
.chip.party.on[data-v=Republican]{background:var(--rep);border-color:var(--rep)}
.chip.party.on[data-v=Libertarian]{background:var(--lib);border-color:var(--lib)}
.chip.party.on[data-v=Independent]{background:var(--ind);border-color:var(--ind)}
.btn{border:1px solid var(--line);background:#fff;border-radius:8px;padding:7px 11px;font:inherit;cursor:pointer;color:var(--ink)}
.btn:hover{background:#faf9f6}
.btn.primary{background:var(--ink);color:#fff;border-color:var(--ink)}
.seg{display:flex;border:1px solid var(--line);border-radius:8px;overflow:hidden}
.seg button{border:0;background:#fff;padding:7px 12px;font:inherit;cursor:pointer;color:var(--muted)}
.seg button.on{background:var(--ink);color:#fff}
.layout{display:grid;grid-template-columns:1fr 320px;gap:20px;margin-top:14px;align-items:start}
@media(max-width:900px){.layout{grid-template-columns:1fr}.stats{grid-template-columns:repeat(3,1fr)}}
.panel{background:var(--panel);border:1px solid var(--line);border-radius:12px;box-shadow:var(--shadow)}
.panel h2{font-size:15px;padding:13px 15px;border-bottom:1px solid var(--line)}
.panel h2 .meta{float:right;font-family:inherit;font-weight:400;font-size:11.5px;color:var(--muted);text-transform:none}
/* leaderboard */
table{width:100%;border-collapse:collapse}
th,td{text-align:left;padding:9px 12px;border-bottom:1px solid var(--line);font-size:13px;vertical-align:middle}
th{font-size:11px;text-transform:uppercase;letter-spacing:.04em;color:var(--muted);cursor:pointer;white-space:nowrap;background:#fbfaf7}
th.sorted::after{content:" ▾";color:var(--ink)}
th.sorted.asc::after{content:" ▴"}
tr.row{cursor:pointer}
tr.row:hover{background:#fbfaf7}
.rank{color:var(--muted);font-variant-numeric:tabular-nums;width:26px}
.nm{font-weight:600}
.nm .role{display:block;font-weight:400;color:var(--muted);font-size:11.5px}
.pbar{display:inline-block;width:3px;height:26px;border-radius:2px;margin-right:9px;vertical-align:middle}
.tier{display:inline-block;font-size:11px;font-weight:600;padding:2px 8px;border-radius:999px;color:#fff;white-space:nowrap}
.scoreCell{font-variant-numeric:tabular-nums;font-weight:600;width:120px}
.track{display:inline-block;width:62px;height:7px;background:#eee;border-radius:4px;overflow:hidden;margin-left:8px;vertical-align:middle}
.track > i{display:block;height:100%;border-radius:4px}
.delta{font-variant-numeric:tabular-nums;font-weight:600;font-size:12px}
.delta.up{color:var(--good)} .delta.dn{color:var(--bad)} .delta.fl{color:var(--muted)}
.conf{font-size:11px;color:var(--muted)}
.dotc{display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:4px;vertical-align:1px}
/* cards */
.cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(248px,1fr));gap:12px;padding:14px}
.card{border:1px solid var(--line);border-radius:11px;padding:13px;background:#fff;cursor:pointer;transition:.12s;position:relative;overflow:hidden}
.card:hover{border-color:#c9c6bd;transform:translateY(-1px)}
.card .accent{position:absolute;left:0;top:0;bottom:0;width:4px}
.card .ch{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-left:6px}
.card .nm2{font-weight:600;font-size:15px}
.card .role2{color:var(--muted);font-size:11.5px}
.card .sig{margin:9px 0 8px 6px;font-size:12.5px;color:#333}
.card .foot{display:flex;justify-content:space-between;align-items:center;margin-left:6px;margin-top:8px}
.scoreBig{font-family:Georgia,serif;font-size:21px;font-weight:600}
/* feed */
.feed{padding:6px 0}
.feed .it{padding:10px 15px;border-bottom:1px solid var(--line)}
.feed .it:last-child{border-bottom:0}
.feed .d{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.03em}
.feed .h{font-size:12.5px;margin-top:3px}
.feed .h b{font-weight:600}
.legend{padding:12px 15px;font-size:12px;color:var(--muted)}
.legend .li{display:flex;gap:8px;align-items:center;margin:6px 0}
.legend .sw{width:26px;flex:0 0 26px;text-align:center}
/* drawer */
.scrim{position:fixed;inset:0;background:rgba(20,20,20,.34);opacity:0;pointer-events:none;transition:.18s;z-index:40}
.scrim.on{opacity:1;pointer-events:auto}
.drawer{position:fixed;top:0;right:0;height:100%;width:430px;max-width:94vw;background:#fff;box-shadow:-8px 0 30px rgba(0,0,0,.16);
  transform:translateX(100%);transition:.22s cubic-bezier(.4,0,.2,1);z-index:50;overflow-y:auto}
.drawer.on{transform:none}
.drawer .dh{padding:18px 20px;border-bottom:1px solid var(--line);position:sticky;top:0;background:#fff;z-index:2}
.drawer .dh .x{float:right;cursor:pointer;font-size:20px;color:var(--muted);line-height:1}
.drawer .body{padding:18px 20px}
.kv{display:grid;grid-template-columns:120px 1fr;gap:6px 12px;font-size:13px;margin:14px 0}
.kv .k{color:var(--muted)}
.quote{border-left:3px solid var(--line);padding:6px 0 6px 13px;color:#333;font-style:italic;margin:12px 0;font-size:13.5px}
.break{margin-top:16px}
.break h4{margin:0 0 7px;font-size:11.5px;text-transform:uppercase;letter-spacing:.04em;color:var(--muted);font-family:inherit;font-weight:700}
.cmp{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px dashed var(--line);font-size:13px}
.cmp .v{font-variant-numeric:tabular-nums;font-weight:600}
.cmp .v.pos{color:var(--good)} .cmp .v.neg{color:var(--bad)}
.cmp.total{border-bottom:0;border-top:2px solid var(--ink);margin-top:4px;padding-top:8px;font-weight:700}
.tagrow{display:flex;flex-wrap:wrap;gap:6px;margin-top:10px}
.tag{font-size:11px;background:#f1efe9;border-radius:5px;padding:3px 7px;color:#555}
/* edit form */
.form label{display:block;font-size:12px;color:var(--muted);margin:10px 0 3px}
.form input[type=text],.form textarea,.form select{width:100%;font:inherit;padding:7px 9px;border:1px solid var(--line);border-radius:7px}
.form textarea{resize:vertical;min-height:46px}
.checks{display:grid;grid-template-columns:1fr 1fr;gap:4px 12px;margin-top:6px}
.checks label{display:flex;align-items:center;gap:6px;font-size:12.5px;color:var(--ink);margin:2px 0}
.livescore{background:#faf9f6;border:1px solid var(--line);border-radius:8px;padding:10px 12px;margin:14px 0;display:flex;justify-content:space-between;align-items:center}
.note{font-size:11.5px;color:var(--muted);background:#faf9f6;border:1px solid var(--line);border-radius:8px;padding:9px 11px;margin-top:8px}
footer{margin-top:26px;padding-top:14px;border-top:1px solid var(--line);font-size:11.5px;color:var(--muted)}
.hide{display:none!important}
.pollLead{font-size:10px;background:#fff3cd;color:#8a6d00;border:1px solid #f0e0a0;border-radius:5px;padding:1px 6px;margin-left:6px;font-weight:600}
</style>
</head>
<body>
<div class="wrap">
  <header class="top">
    <div class="brand">
      <h1>🧭 Hat-in-Ring Radar</h1>
      <div class="sub">2028 presidential signal tracker</div>
    </div>
    <div class="asof">
      As of <b id="asof">{{ as_of }}</b><br>
      <span id="counter"></span><br>
      <span class="buildstamp" title="Last automated rebuild (UTC in CI)">auto-built {{ generated_at_human }}</span>
    </div>
  </header>

  <div class="stats" id="stats"></div>

  <div class="toolbar">
    <div class="grow"><input type="search" id="q" placeholder="Search name or role…"></div>
    <div class="chips" id="partyChips"></div>
    <select id="bucketSel" title="Seriousness bucket">
      <option value="">All buckets</option>
      <option value="formal">Formal (declared/exploratory)</option>
      <option value="considering">Actively considering</option>
      <option value="soft">Soft / positioning</option>
      <option value="edge">Edge / conditional</option>
      <option value="out">Ruled out / inactive</option>
    </select>
    <select id="confSel" title="Min confidence">
      <option value="">Any confidence</option>
      <option value="3">Verified only (High+)</option>
      <option value="2">Medium+</option>
      <option value="1">Hide noise</option>
    </select>
    <div class="seg" id="viewSeg">
      <button data-view="board" class="on">Leaderboard</button>
      <button data-view="cards">Cards</button>
    </div>
    <button class="btn" id="addBtn">+ Add</button>
    <button class="btn" id="exportBtn" title="Download data as JSON">Export</button>
  </div>

  <div class="layout">
    <div>
      <div class="panel" id="boardPanel">
        <h2>Seriousness leaderboard <span class="meta" id="boardMeta"></span></h2>
        <table id="board"><thead><tr>
          <th class="rank">#</th>
          <th data-sort="name">Candidate</th>
          <th data-sort="party">Lane</th>
          <th data-sort="tierRank">Status</th>
          <th data-sort="score" class="sorted">Momentum</th>
          <th data-sort="delta">7‑day</th>
          <th data-sort="confRank">Conf.</th>
        </tr></thead><tbody id="boardBody"></tbody></table>
      </div>
      <div class="panel hide" id="cardsPanel">
        <h2>Candidate cards <span class="meta" id="cardsMeta"></span></h2>
        <div class="cards" id="cards"></div>
      </div>
    </div>

    <aside>
      <div class="panel" style="margin-bottom:16px">
        <h2>Today's movement <span class="meta">latest signals</span></h2>
        <div class="feed" id="feed"></div>
      </div>
      <div class="panel">
        <h2>Status tiers</h2>
        <div class="legend" id="legend"></div>
      </div>
    </aside>
  </div>

  <footer id="foot"></footer>
</div>

<!-- drawer -->
<div class="scrim" id="scrim"></div>
<div class="drawer" id="drawer"><div id="drawerInner"></div></div>

<script>
const GENERATED_AT = {{ generated_at }};   // build timestamp (drives recency maths)
/* ============================================================
   SCORING ENGINE  (refined model — see footer / spec notes)
   Two orthogonal axes:
     • STATUS TIER = furthest verifiable step taken (categorical)
     • MOMENTUM SCORE 0–100 = weighted sum of activity signals
   Status takes the single highest legal/declarative signal (no
   stacking). Momentum adds behavioural signals + a continuous
   recency term so scores cool over time instead of a single cliff.
   ============================================================ */
const TODAY = new Date(GENERATED_AT);

const WEIGHTS = {
  declared:        {w:40, label:'Formal FEC candidacy / launch'},
  exploratory:     {w:30, label:'Exploratory committee'},
  consideringQuote:{w:20, label:'Direct "considering" quote'},
  softConsidering: {w:12, label:'Soft / "not ruling out" quote'},
  earlyState:      {w:10, label:'Early-state travel (IA/NH/SC/NV)'},
  donors:          {w:10, label:'Donor meetings / PAC activity'},
  staffing:        {w:10, label:'Campaign staffing / consultants'},
  mediaBlitz:      {w:5,  label:'National media blitz'},
  endorsedOther:   {w:-20,label:'Endorsed another likely candidate'},
  ruledOut:        {w:-40,label:'Explicitly ruled out'},
  barred:          {w:-100,label:'Constitutionally ineligible'}
};
const TIERS = {
  5:{label:'Declared',      c:'var(--t5)'},
  4:{label:'Exploratory',   c:'var(--t4)'},
  3:{label:'Considering',   c:'var(--t3)'},
  2:{label:'Positioning',   c:'var(--t2)'},
  1:{label:'Floated',       c:'var(--t1)'},
  0:{label:'Inactive',      c:'var(--t0)'}
};
const CONF = {'Very high':4,'High':3,'Medium':2,'Low':1,'Noise':0};
const CONFC = {'Very high':'var(--good)','High':'#3a8f55','Medium':'var(--lib)','Low':'#b08a2a','Noise':'#b0b0b0'};
const PARTYC = {Democrat:'var(--dem)',Republican:'var(--rep)',Libertarian:'var(--lib)',Independent:'var(--ind)'};

function daysSince(d){return Math.floor((TODAY-new Date(d))/86400000);}
function recencyTerm(d){const n=daysSince(d); if(n<=30)return {w:5,label:`Recency boost (signal ${n}d ago)`}; if(n>90)return {w:-10,label:`Stale (no signal ${n}d)`}; return null;}

function deriveStatus(keys){
  if(keys.includes('barred')) return {tier:0,label:'Ineligible (22nd Amdt)'};
  if(keys.includes('ruledOut')) return {tier:0,label:'Ruled out'};
  if(keys.includes('declared')) return {tier:5,label:'Declared'};
  if(keys.includes('exploratory')) return {tier:4,label:'Exploratory'};
  if(keys.includes('consideringQuote')) return {tier:3,label:'Actively considering'};
  const behav = keys.some(k=>['earlyState','donors','staffing','mediaBlitz'].includes(k));
  if(behav) return {tier:2,label:'Positioning'};
  if(keys.includes('softConsidering')) return {tier:1,label:'Floated / not ruling out'};
  return {tier:0,label:'Inactive'};
}
function breakdown(c){
  const items=[];
  // status axis: single highest declarative signal only
  const order=['declared','exploratory','consideringQuote','softConsidering'];
  const top=order.find(k=>c.keys.includes(k));
  if(top) items.push({label:WEIGHTS[top].label,w:WEIGHTS[top].w});
  // behavioural: all of them stack
  ['earlyState','donors','staffing','mediaBlitz'].forEach(k=>{ if(c.keys.includes(k)) items.push({label:WEIGHTS[k].label,w:WEIGHTS[k].w}); });
  // recency
  const r=recencyTerm(c.lastSignal); if(r) items.push(r);
  // penalties
  ['endorsedOther','ruledOut','barred'].forEach(k=>{ if(c.keys.includes(k)) items.push({label:WEIGHTS[k].label,w:WEIGHTS[k].w}); });
  return items;
}
function score(c){
  let s=breakdown(c).reduce((a,b)=>a+b.w,0);
  return Math.max(0,Math.min(100,s));
}

/* ============================================================
   SEED DATA  — compiled from Dave's vetted 2028 list (Jun 12 2026)
   Sources: AP, Reuters, Time, WaPo, ABC, C-SPAN, FEC, Wikipedia.
   keys[] drive both status and score; edit/add persists locally.
   ============================================================ */
const SEED = {{ seed_json }};

/* ---------- persistence ---------- */
const LS='hatInRing_v1';
function load(){
  let saved=null;
  try{ const raw=localStorage.getItem(LS); saved=raw?JSON.parse(raw):null; }catch(e){}
  const fresh=JSON.parse(JSON.stringify(SEED));
  if(!saved||!saved.records||!saved.records.length) return {records:fresh,prefs:{},ver:GENERATED_AT};
  if(saved.ver===GENERATED_AT) return saved;            // same pipeline build → keep user edits
  const manual=saved.records.filter(r=>String(r.id).startsWith('c')); // preserve manual-only adds
  return {records:fresh.concat(manual),prefs:saved.prefs||{},ver:GENERATED_AT};
}
function save(){ try{localStorage.setItem(LS,JSON.stringify(DB));}catch(e){} }
let DB=load();
let PREFS=DB.prefs||{view:'board',party:[],bucket:'',conf:'',q:'',sort:'score',dir:'desc'};

/* ---------- derived ---------- */
function enrich(c){
  const st=deriveStatus(c.keys); const sc=score(c);
  return Object.assign({},c,{tier:st.tier,statusLabel:st.label,tierRank:st.tier,score:sc,
    confRank:CONF[c.conf]??0});
}
function records(){ return DB.records.map(enrich); }

/* ---------- filtering ---------- */
function filtered(){
  let r=records();
  if(PREFS.party.length) r=r.filter(x=>PREFS.party.includes(x.party));
  if(PREFS.bucket) r=r.filter(x=>x.bucket===PREFS.bucket);
  if(PREFS.conf) r=r.filter(x=>x.confRank>=+PREFS.conf);
  if(PREFS.q){const q=PREFS.q.toLowerCase(); r=r.filter(x=>(x.name+' '+x.role).toLowerCase().includes(q));}
  const dir=PREFS.dir==='asc'?1:-1;
  r.sort((a,b)=>{
    let va=a[PREFS.sort],vb=b[PREFS.sort];
    if(typeof va==='string'){return va.localeCompare(vb)*dir;}
    if(va===vb){return b.score-a.score;}
    return (va-vb)*dir;
  });
  return r;
}

/* ---------- render ---------- */
const $=s=>document.querySelector(s);
function partyColor(p){return PARTYC[p]||'var(--other)';}

function renderStats(){
  const r=records();
  const by=t=>r.filter(x=>x.tier===t).length;
  const cards=[
    {n:r.filter(x=>x.bucket==='formal').length,l:'Formal',c:'var(--t4)'},
    {n:r.filter(x=>x.tier===3).length,l:'Considering',c:'var(--t3)'},
    {n:r.filter(x=>x.tier===2).length,l:'Positioning',c:'var(--t2)'},
    {n:r.filter(x=>x.tier===1).length,l:'Floated',c:'var(--t1)'},
    {n:r.filter(x=>x.bucket==='out').length,l:'Ruled out',c:'var(--t0)'},
    {n:r.length,l:'Tracked',c:'var(--ink)'}
  ];
  $('#stats').innerHTML=cards.map(c=>`<div class="stat"><div class="n">${c.n}</div><div class="l"><span class="dot" style="background:${c.c}"></span>${c.l}</div></div>`).join('');
  $('#counter').textContent=`${r.length} names · ${r.filter(x=>daysSince(x.lastSignal)<=14).length} moved this fortnight`;
}

function tierBadge(x){return `<span class="tier" style="background:${TIERS[x.tier].c}">${x.statusLabel}</span>`;}
function deltaHTML(d){const cls=d>0?'up':d<0?'dn':'fl';const s=d>0?'▲ +'+d:d<0?'▼ '+d:'– 0';return `<span class="delta ${cls}">${s}</span>`;}
function confHTML(c){return `<span class="conf"><span class="dotc" style="background:${CONFC[c]}"></span>${c}</span>`;}

function renderBoard(){
  const r=filtered();
  $('#boardMeta').textContent=r.length+' shown';
  $('#boardBody').innerHTML=r.map((x,i)=>`
    <tr class="row" data-id="${x.id}">
      <td class="rank">${i+1}</td>
      <td><span class="pbar" style="background:${partyColor(x.party)}"></span>
          <span class="nm">${x.name}${x.pollLead?`<span class="pollLead">★</span>`:''}<span class="role">${x.role}</span></span></td>
      <td>${x.party}</td>
      <td>${tierBadge(x)}</td>
      <td class="scoreCell">${x.score}<span class="track"><i style="width:${x.score}%;background:${TIERS[x.tier].c}"></i></span></td>
      <td>${deltaHTML(x.delta)}</td>
      <td>${confHTML(x.conf)}</td>
    </tr>`).join('');
  document.querySelectorAll('#board th[data-sort]').forEach(th=>{
    th.classList.toggle('sorted',th.dataset.sort===PREFS.sort);
    th.classList.toggle('asc',PREFS.dir==='asc');
  });
}
function renderCards(){
  const r=filtered();
  $('#cardsMeta').textContent=r.length+' shown';
  $('#cards').innerHTML=r.map(x=>`
    <div class="card" data-id="${x.id}">
      <span class="accent" style="background:${partyColor(x.party)}"></span>
      <div class="ch"><div><div class="nm2">${x.name}</div><div class="role2">${x.role}</div></div>${tierBadge(x)}</div>
      <div class="sig">${x.headline}</div>
      <div class="foot"><div class="scoreBig" style="color:${TIERS[x.tier].c}">${x.score}</div>
        <div style="text-align:right">${deltaHTML(x.delta)}<br>${confHTML(x.conf)}</div></div>
    </div>`).join('');
}
function renderFeed(){
  const r=records().filter(x=>x.bucket!=='out'||x.delta!==0)
    .sort((a,b)=>new Date(b.lastSignal)-new Date(a.lastSignal)).slice(0,9);
  $('#feed').innerHTML=r.map(x=>{
    const d=new Date(x.lastSignal).toLocaleDateString('en-US',{month:'short',day:'numeric'});
    return `<div class="it" data-id="${x.id}" style="cursor:pointer">
      <div class="d">${d} · ${x.party} ${x.delta?'· '+deltaHTML(x.delta):''}</div>
      <div class="h"><b>${x.name}</b> — ${x.headline}</div></div>`;
  }).join('');
}
function renderLegend(){
  $('#legend').innerHTML=Object.entries(TIERS).sort((a,b)=>b[0]-a[0]).map(([t,o])=>
    `<div class="li"><span class="sw"><span class="tier" style="background:${o.c};padding:2px 6px">${t}</span></span><span>${({5:'Declared — FEC Form 2 / launch',4:'Exploratory committee / testing-the-waters org',3:'Direct "considering" quote',2:'Positioning — travel, donors, staff, media',1:'Floated / "not ruling out"',0:'Ruled out / ineligible / inactive'})[t]}</span></div>`
  ).join('')+`<div class="note">★ = leads primary polling despite lower status tier (status ≠ support).</div>`;
}
function renderAll(){renderStats();renderBoard();renderCards();renderFeed();renderLegend();syncControls();}

/* ---------- drawer ---------- */
function openDrawer(id){
  const c=DB.records.find(x=>x.id===id); if(!c)return;
  const x=enrich(c); const bd=breakdown(c);
  const total=x.score;
  $('#drawerInner').innerHTML=`
    <div class="dh">
      <span class="x" data-close>×</span>
      <h2 style="font-size:20px">${x.name}</h2>
      <div style="color:var(--muted);font-size:12.5px;margin-top:3px">${x.role} · <span style="color:${partyColor(x.party)};font-weight:600">${x.party}</span></div>
      <div style="margin-top:9px">${tierBadge(x)} ${confHTML(x.conf)} ${deltaHTML(x.delta)}${x.pollLead?` <span class="pollLead">★ ${x.pollLead}</span>`:''}</div>
    </div>
    <div class="body">
      <div class="kv">
        <div class="k">Latest signal</div><div>${x.headline}</div>
        <div class="k">Why it matters</div><div>${x.why}</div>
        <div class="k">Last signal</div><div>${new Date(x.lastSignal).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'})} · ${daysSince(x.lastSignal)} days ago</div>
        <div class="k">Bucket</div><div>${({formal:'Formal (declared/exploratory)',considering:'Actively considering',soft:'Soft / positioning',edge:'Edge / conditional',out:'Ruled out / inactive'})[x.bucket]}</div>
      </div>
      ${x.quote?`<div class="quote">"${x.quote}"</div>`:''}
      <div class="break">
        <h4>Why this momentum score?</h4>
        ${bd.map(b=>`<div class="cmp"><span>${b.label}</span><span class="v ${b.w>=0?'pos':'neg'}">${b.w>=0?'+':''}${b.w}</span></div>`).join('')||'<div class="cmp"><span>No active signals</span><span class="v">0</span></div>'}
        <div class="cmp total"><span>Momentum (capped 0–100)</span><span class="v">${total}</span></div>
      </div>
      ${x.tags&&x.tags.length?`<div class="tagrow">${x.tags.map(t=>`<span class="tag">${t}</span>`).join('')}</div>`:''}
      <div style="margin-top:18px;display:flex;gap:8px">
        <button class="btn" data-edit="${x.id}">Edit</button>
        <button class="btn" data-del="${x.id}">Delete</button>
      </div>
      <div class="note" style="margin-top:14px">Momentum = breadth & recency of activity. Status tier = furthest verifiable step taken. They move independently — a downplaying front-runner can sit at "Floated" with mid momentum.</div>
    </div>`;
  showDrawer();
}
const ALLKEYS=['declared','exploratory','consideringQuote','softConsidering','earlyState','donors','staffing','mediaBlitz','endorsedOther','ruledOut','barred'];
function editForm(id){
  const c=id?DB.records.find(x=>x.id===id):{id:'',name:'',party:'Democrat',role:'',bucket:'considering',keys:[],conf:'Medium',delta:0,lastSignal:TODAY.toISOString().slice(0,10),headline:'',why:'',quote:'',tags:[]};
  $('#drawerInner').innerHTML=`
    <div class="dh"><span class="x" data-close>×</span><h2 style="font-size:19px">${id?'Edit':'Add'} candidate</h2></div>
    <div class="body form">
      <label>Name</label><input type="text" id="f-name" value="${c.name||''}">
      <label>Role / current office</label><input type="text" id="f-role" value="${c.role||''}">
      <div style="display:flex;gap:10px">
        <div style="flex:1"><label>Party / lane</label><select id="f-party">${['Democrat','Republican','Libertarian','Independent'].map(p=>`<option ${c.party===p?'selected':''}>${p}</option>`).join('')}</select></div>
        <div style="flex:1"><label>Bucket</label><select id="f-bucket">${[['formal','Formal'],['considering','Considering'],['soft','Soft/positioning'],['edge','Edge'],['out','Ruled out']].map(([v,l])=>`<option value="${v}" ${c.bucket===v?'selected':''}>${l}</option>`).join('')}</select></div>
      </div>
      <label>Signals present (drive status + score)</label>
      <div class="checks">${ALLKEYS.map(k=>`<label><input type="checkbox" class="f-key" value="${k}" ${c.keys.includes(k)?'checked':''}> ${WEIGHTS[k].label} <span style="color:var(--muted)">(${WEIGHTS[k].w>0?'+':''}${WEIGHTS[k].w})</span></label>`).join('')}</div>
      <div style="display:flex;gap:10px">
        <div style="flex:1"><label>Confidence</label><select id="f-conf">${Object.keys(CONF).map(k=>`<option ${c.conf===k?'selected':''}>${k}</option>`).join('')}</select></div>
        <div style="flex:1"><label>7-day delta</label><input type="text" id="f-delta" value="${c.delta||0}"></div>
        <div style="flex:1"><label>Last signal</label><input type="text" id="f-date" value="${c.lastSignal}"></div>
      </div>
      <label>Latest signal (headline)</label><input type="text" id="f-headline" value="${(c.headline||'').replace(/"/g,'&quot;')}">
      <label>Why it matters</label><textarea id="f-why">${c.why||''}</textarea>
      <label>Best quote (optional)</label><textarea id="f-quote">${c.quote||''}</textarea>
      <label>Tags (comma-separated)</label><input type="text" id="f-tags" value="${(c.tags||[]).join(', ')}">
      <div class="livescore"><span>Live status / momentum</span><span id="f-live" style="font-weight:700"></span></div>
      <div style="display:flex;gap:8px;margin-top:12px">
        <button class="btn primary" data-save="${id||''}">Save</button>
        <button class="btn" data-close>Cancel</button>
      </div>
    </div>`;
  showDrawer();
  const upd=()=>{
    const keys=[...document.querySelectorAll('.f-key:checked')].map(e=>e.value);
    const tmp={keys,lastSignal:$('#f-date').value};
    const st=deriveStatus(keys);
    $('#f-live').innerHTML=`<span class="tier" style="background:${TIERS[st.tier].c}">${st.label}</span> · ${score(tmp)}`;
  };
  document.querySelectorAll('.f-key').forEach(e=>e.addEventListener('change',upd));
  $('#f-date').addEventListener('input',upd); upd();
}
function saveForm(id){
  const keys=[...document.querySelectorAll('.f-key:checked')].map(e=>e.value);
  const rec={
    id:id||('c'+Date.now()),
    name:$('#f-name').value.trim()||'Untitled',
    role:$('#f-role').value.trim(),
    party:$('#f-party').value, bucket:$('#f-bucket').value,
    keys, conf:$('#f-conf').value, delta:parseInt($('#f-delta').value)||0,
    lastSignal:$('#f-date').value, headline:$('#f-headline').value.trim(),
    why:$('#f-why').value.trim(), quote:$('#f-quote').value.trim(),
    tags:$('#f-tags').value.split(',').map(s=>s.trim()).filter(Boolean)
  };
  const i=DB.records.findIndex(x=>x.id===id);
  if(i>=0)DB.records[i]=rec; else DB.records.push(rec);
  save(); renderAll(); closeDrawer();
}
function delRec(id){ DB.records=DB.records.filter(x=>x.id!==id); save(); renderAll(); closeDrawer(); }

function showDrawer(){$('#drawer').classList.add('on');$('#scrim').classList.add('on');}
function closeDrawer(){$('#drawer').classList.remove('on');$('#scrim').classList.remove('on');}

/* ---------- controls ---------- */
function syncControls(){
  $('#q').value=PREFS.q||'';
  $('#bucketSel').value=PREFS.bucket||'';
  $('#confSel').value=PREFS.conf||'';
  document.querySelectorAll('#viewSeg button').forEach(b=>b.classList.toggle('on',b.dataset.view===PREFS.view));
  $('#boardPanel').classList.toggle('hide',PREFS.view!=='board');
  $('#cardsPanel').classList.toggle('hide',PREFS.view!=='cards');
  document.querySelectorAll('.chip.party').forEach(c=>c.classList.toggle('on',PREFS.party.includes(c.dataset.v)));
}
function persistPrefs(){DB.prefs=PREFS;save();}

function init(){
  // party chips
  $('#partyChips').innerHTML=['Democrat','Republican','Libertarian','Independent'].map(p=>`<span class="chip party" data-v="${p}">${p.slice(0,3)}</span>`).join('');
  document.querySelectorAll('.chip.party').forEach(c=>c.addEventListener('click',()=>{
    const v=c.dataset.v; const i=PREFS.party.indexOf(v);
    if(i>=0)PREFS.party.splice(i,1); else PREFS.party.push(v);
    persistPrefs();renderBoard();renderCards();syncControls();
  }));
  $('#q').addEventListener('input',e=>{PREFS.q=e.target.value;persistPrefs();renderBoard();renderCards();});
  $('#bucketSel').addEventListener('change',e=>{PREFS.bucket=e.target.value;persistPrefs();renderBoard();renderCards();});
  $('#confSel').addEventListener('change',e=>{PREFS.conf=e.target.value;persistPrefs();renderBoard();renderCards();});
  document.querySelectorAll('#viewSeg button').forEach(b=>b.addEventListener('click',()=>{PREFS.view=b.dataset.view;persistPrefs();syncControls();}));
  document.querySelectorAll('#board th[data-sort]').forEach(th=>th.addEventListener('click',()=>{
    const s=th.dataset.sort;
    if(PREFS.sort===s)PREFS.dir=PREFS.dir==='asc'?'desc':'asc';
    else{PREFS.sort=s;PREFS.dir=(s==='name'||s==='party')?'asc':'desc';}
    persistPrefs();renderBoard();
  }));
  $('#addBtn').addEventListener('click',()=>editForm(null));
  $('#exportBtn').addEventListener('click',()=>{
    const blob=new Blob([JSON.stringify(DB.records,null,2)],{type:'application/json'});
    const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='hat-in-ring-2028.json';a.click();
  });
  // delegated clicks
  document.body.addEventListener('click',e=>{
    const row=e.target.closest('[data-id]');
    if(e.target.closest('[data-close]')){closeDrawer();return;}
    if(e.target.closest('[data-save]')!==null){saveForm(e.target.closest('[data-save]').dataset.save||'');return;}
    if(e.target.closest('[data-edit]')){editForm(e.target.closest('[data-edit]').dataset.edit);return;}
    if(e.target.closest('[data-del]')){if(confirm('Remove this candidate?'))delRec(e.target.closest('[data-del]').dataset.del);return;}
    if(row&&!e.target.closest('.drawer')){openDrawer(row.dataset.id);}
  });
  $('#scrim').addEventListener('click',closeDrawer);
  document.addEventListener('keydown',e=>{if(e.key==='Escape')closeDrawer();});

  $('#foot').innerHTML=`Manually-maintained tracker — data seeded from public reporting (AP, Reuters, Time, WaPo, ABC, C-SPAN, FEC) as of {{ as_of }} (auto-generated {{ generated_at_human }}). Edits/additions save to this browser only; use <b>Export</b> to back up or port to Notion. <b>Status tier</b> = furthest verifiable step taken; <b>momentum</b> = weighted activity + recency, capped 0–100. Not a live FEC/news feed — see chat notes for wiring options.`;
  renderAll();
}
init();
</script>
</body>
</html>
